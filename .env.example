# Shreevan CRM — environment template
#
# This prototype is front-end only and reads NONE of these at runtime; they
# document what a backend implementation of the Unified Inbox would require.
# Never commit real secrets. Secrets must live server-side only — never exposed
# to the browser (no VITE_ prefix for provider tokens).

# --- App ---
# PUBLIC_APP_URL=https://crm.shreevanwellness.com

# --- Inbound webhook endpoints (backend routes to implement) ---
# /api/inbound/website     website enquiry & application forms
# /api/inbound/whatsapp    Meta WhatsApp Business webhook
# /api/inbound/instagram   Meta Instagram messaging webhook
# /api/inbound/facebook    Meta Messenger webhook
# /api/inbound/email       IMAP poller / Microsoft Graph push

# --- WhatsApp Business (Meta Cloud API) ---
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_APP_SECRET=            # used to verify X-Hub-Signature-256
# WHATSAPP_VERIFY_TOKEN=

# --- Instagram + Facebook Messenger (Meta) ---
# META_APP_ID=
# META_APP_SECRET=                # webhook signature verification
# META_PAGE_ACCESS_TOKEN=
# META_VERIFY_TOKEN=

# --- Email (IMAP or Microsoft Graph) ---
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_USER=
# EMAIL_IMAP_PASSWORD=
# or
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=

# --- Database (when lifting the in-memory model to an API) ---
# DATABASE_URL=postgres://user:pass@host:5432/shreevan_crm

# --- Simulation ---
# INBOX_SIMULATION_MODE=true      # must be false/unset in production
