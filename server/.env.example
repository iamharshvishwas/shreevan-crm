# Shreevan CRM backend — environment. Copy to .env and fill in. No real secrets in git.

NODE_ENV=development
PORT=3000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://shreevan:shreevan@localhost:5432/shreevan_crm?schema=public

# Auth — generate strong random secrets for production (openssl rand -hex 32)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)

# CORS — the Vite frontend origin
CORS_ORIGIN=http://localhost:5173

# Feature flags
ENABLE_SIMULATION=true        # dev-only inbound simulation; MUST be false in production

# Redis (reserved for BullMQ in a later phase; not required to boot today)
# REDIS_URL=redis://localhost:6379

# Secrets store for provider tokens (abstraction; never store raw tokens in DB)
# SECRETS_DRIVER=env           # env | aws-sm | vault

# --- Provider credentials (awaiting setup — adapters are simulated until present) ---
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_APP_SECRET=          # verifies X-Hub-Signature-256
# META_APP_SECRET=
# META_PAGE_ACCESS_TOKEN=
# --- Email (Veda) — business mailbox, e.g. contact@shreevanwellness.com ---
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=contact@shreevanwellness.com
# SMTP_PASS=
# VEDA_FROM_EMAIL=Veda · Shreevan Wellness <contact@shreevanwellness.com>
# IMAP_HOST=imap.hostinger.com   # optional — enables Veda reading + auto-replying to inbound mail
# IMAP_PORT=993
# IMAP_MAILBOX=INBOX
# S3_ENDPOINT=
# S3_BUCKET=
